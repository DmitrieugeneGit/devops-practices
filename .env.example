# Шаблон настроек. Скопируйте в .env:  cp .env.example .env
# Внимание: сам Go-код читает переменные ИЗ ОКРУЖЕНИЯ, а не из .env напрямую.
# Чтобы применить .env: перед запуском выполнить  set -a; source ../.env; set +a

# HTTP-сервер
HTTP_ADDR=:8080

# Путь к статике фронтенда (относительно каталога backend при go run)
FRONTEND_DIR=../frontend

# --- Подключение к PostgreSQL ---
# Вариант 1: целиком через DATABASE_URL (имеет приоритет)
# DATABASE_URL=postgres://tasks_user:tasks_pass@localhost:5432/tasks_db?sslmode=disable

# Вариант 2: по частям
DB_HOST=localhost
DB_PORT=5432
DB_USER=tasks_user
DB_PASSWORD=tasks_pass
DB_NAME=tasks_db
DB_SSLMODE=disable
